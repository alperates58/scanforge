APP_NAME=ScanForge
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3003
CORS_ALLOWED_ORIGINS=http://localhost:3003
SCANFORGE_VERSION=0.7.0-phase07

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=scanforge
DB_USERNAME=scanforge
DB_PASSWORD=change-me

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

ALLOW_UNVERIFIED_DOMAINS=false
SCAN_SAFE_MODE=true
SCAN_DEFAULT_TIMEOUT_SECONDS=900
SCAN_MAX_CONCURRENT_JOBS=2
SCAN_SAME_TARGET_COOLDOWN_MINUTES=15
SCANFORGE_ENABLE_DEEP_SCAN=false
SCANFORGE_WORKER_ID=
SCANFORGE_WORKER_MAX_JOBS=1
SCANFORGE_WORKER_HEARTBEAT_SECONDS=30
SCANFORGE_SCAN_LOCK_TTL_SECONDS=900
SCANFORGE_JOB_TIMEOUT_SECONDS=300
SCANFORGE_JOB_MAX_REQUESTS=50
SCANFORGE_JOB_MAX_RUNTIME=300
SCANFORGE_JOB_MAX_MEMORY_MB=256
SCANFORGE_RETRY_DEFAULT_MAX_ATTEMPTS=2
SCANFORGE_RETRY_DEFAULT_BACKOFF_SECONDS=30
SCANFORGE_RETRY_NUCLEI_MAX_ATTEMPTS=3
SCANFORGE_RETRY_ZAP_MAX_ATTEMPTS=1
NUCLEI_ENABLED=false
NUCLEI_VERSION=3.10.0
NUCLEI_BINARY_PATH=/usr/local/bin/nuclei
NUCLEI_TEMPLATES_PATH=/opt/nuclei-templates
NUCLEI_DEFAULT_TIMEOUT_SECONDS=300
NUCLEI_MAX_REQUESTS=100
NUCLEI_RATE_LIMIT_PER_SECOND=2
NUCLEI_ALLOWED_SEVERITIES=info,low,medium,high,critical
NUCLEI_SAFE_TEMPLATE_TAGS=exposure,misconfig,headers,ssl,tech,cve,config
NUCLEI_BLOCKED_TEMPLATE_TAGS=dos,fuzz,fuzzing,brute-force,bruteforce,intrusive,destructive,aggressive,dast
NUCLEI_INTEGRATION_TEST=false
SCANFORGE_SCANNER_TMP=/tmp/scanforge
SCAN_PASSIVE_RPS=1
SCAN_STANDARD_RPS=3
SCAN_DEEP_RPS=5
DOMAIN_VERIFICATION_TIMEOUT_SECONDS=5
DOMAIN_VERIFICATION_MAX_REDIRECTS=3
DISCOVERY_TIMEOUT_SECONDS=5
DISCOVERY_MAX_REDIRECTS=5
DISCOVERY_MAX_BODY_BYTES=262144
DISCOVERY_WHOIS_ENABLED=false
DISCOVERY_REVERSE_DNS_ENABLED=false
SCANFORGE_FINGERPRINT_ANALYSIS_VERSION=fingerprint-v1
SCANNER_MOCK_WORKER_ENABLED=true
