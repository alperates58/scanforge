{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScanForgeFinding",
  "type": "object",
  "required": ["title", "severity", "confidence", "affected_url", "source_tool", "evidence"],
  "properties": {
    "title": {"type": "string"},
    "severity": {"enum": ["info", "low", "medium", "high", "critical"]},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "affected_url": {"type": "string"},
    "source_tool": {"type": "string"},
    "cwe": {"type": ["string", "null"]},
    "cve": {"type": ["string", "null"]},
    "cvss": {"type": ["number", "null"]},
    "owasp_category": {"type": ["string", "null"]},
    "evidence": {"type": "string"},
    "remediation": {"type": ["string", "null"]},
    "fingerprint_hash": {"type": ["string", "null"]}
  }
}
